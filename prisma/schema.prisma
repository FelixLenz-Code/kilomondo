generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

// Access level a vehicle owner grants to another user via a VehicleShare.
// VIEWER may only read; EDITOR may also add/edit/delete entries.
enum ShareRole {
  VIEWER
  EDITOR
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  LPG
}

enum RepairCategory {
  REPAIR
  SERVICE
  INSPECTION
  TIRES
  OTHER
}

enum CleaningType {
  INTERIOR
  EXTERIOR
  FULL
}

enum ReminderType {
  INSPECTION // TÜV / HU
  SERVICE    // Wartung / Inspektion
  INSURANCE  // Versicherung
  TAX        // Kfz-Steuer
  LOG        // Erinnerung, etwas einzutragen
  CUSTOM
}

enum ImageKind {
  BEFORE
  AFTER
}

enum AnimationStatus {
  NONE
  PENDING
  READY
  FAILED
}

// CAR = fuel pumped straight into the car. CANISTER = fuel poured into the car
// from a canister (already paid for when the canister was filled; the cost is
// realised here from the canister's average price).
enum FuelEntryKind {
  CAR
  CANISTER
}

model Image {
  id         String     @id @default(cuid())
  mimeType   String
  data       Bytes
  createdAt  DateTime   @default(now())
  // Optional linkage for before/after galleries (cover images are referenced
  // directly via Vehicle.coverImageId instead).
  repairId   String?
  cleaningId String?
  kind       ImageKind?

  @@index([repairId])
  @@index([cleaningId])
}

// A file (invoice, report, …) attached to a repair entry. Stored inline like
// Image; the link is by id only (no FK), so deletes are handled in app code.
model Attachment {
  id        String   @id @default(cuid())
  mimeType  String
  fileName  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())
  repairId  String?

  @@index([repairId])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions  Session[]
  vehicles  Vehicle[]
  canisters Canister[]
  // Vehicles owned by others that have been shared with this user.
  sharedVehicles VehicleShare[]
  pushSubscriptions PushSubscription[]
}

// A Web Push subscription for one browser/device of a user. Multiple per user.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Simple key/value store for server-side app config that must persist and be
// generated at runtime (e.g. the VAPID keypair for Web Push), so it survives
// updates without any .env changes.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Vehicle {
  id             String   @id @default(cuid())
  userId         String
  name           String
  make           String?
  model          String?
  year           Int?
  licensePlate   String?
  vin            String?
  fuelType       FuelType @default(PETROL)
  color          String?
  // Optional: show an "also refueled AdBlue" checkbox + price field on fuel entries.
  adblueTracking Boolean  @default(false)
  coverImageId   String?
  // Optional 3D intro animation rendered from an uploaded GLB model. The video
  // and its poster frame are stored as Image rows; status tracks the async render.
  animationVideoId  String?
  animationPosterId String?
  animationStatus   AnimationStatus @default(NONE)
  initialOdometer Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelEntries    FuelEntry[]
  odometerEntries OdometerEntry[]
  repairEntries  RepairEntry[]
  cleaningEntries CleaningEntry[]
  shares         VehicleShare[]
  reminders      Reminder[]

  @@index([userId])
}

// A due-date / due-mileage reminder for a vehicle. The owner is notified when
// it comes due. Evaluated by the in-process scheduler (see lib/reminder-scheduler).
model Reminder {
  id               String       @id @default(cuid())
  vehicleId        String
  type             ReminderType @default(CUSTOM)
  title            String
  dueDate          DateTime?
  dueOdometer      Int?
  // Notify this many days before dueDate.
  leadDays         Int          @default(28)
  // LOG reminders: notify when no entry was made for this many days.
  intervalDays     Int?
  // Roll dueDate forward by this many months after it passes (recurring dates).
  recurrenceMonths Int?
  // MANUAL or AUTO (auto-suggested from history).
  source           String       @default("MANUAL")
  active           Boolean      @default(true)
  lastNotifiedAt   DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

// Grants another user access to a vehicle they don't own. The owner manages
// these; the granted user sees the vehicle in their garage with the given role.
model VehicleShare {
  id        String    @id @default(cuid())
  vehicleId String
  userId    String
  role      ShareRole @default(EDITOR)
  createdAt DateTime  @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, userId])
  @@index([userId])
  @@index([vehicleId])
}

model FuelEntry {
  id          String        @id @default(cuid())
  vehicleId   String
  date        DateTime
  odometer    Int
  amount      Float    // liters or kWh
  pricePerUnit Float
  totalCost   Float
  isFullTank  Boolean       @default(true)
  station     String?
  notes       String?
  // Optional AdBlue top-up cost recorded with this fueling (no volume tracked).
  adbluePrice Float?
  kind        FuelEntryKind @default(CAR)
  // Set when kind = CANISTER: which canister the fuel was poured from.
  canisterId  String?
  createdAt   DateTime      @default(now())

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  canister Canister? @relation(fields: [canisterId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([canisterId])
}

// A jerry can / fuel canister. Shared across the user's vehicles (a physical
// can can fuel any of them). Current contents and value are derived from its
// fills minus the FuelEntry pours that drew from it.
model Canister {
  id        String    @id @default(cuid())
  userId    String
  name      String
  capacity  Float // liters it can hold
  fuelType  FuelType?
  notes     String?
  createdAt DateTime  @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fills CanisterFill[]
  pours FuelEntry[]

  @@index([userId])
}

// A purchase of fuel into a canister (at a station). Money is "parked" here
// until the fuel is later poured into a car (a FuelEntry with kind = CANISTER).
model CanisterFill {
  id           String   @id @default(cuid())
  canisterId   String
  date         DateTime
  liters       Float
  pricePerUnit Float
  totalCost    Float
  station      String?
  notes        String?
  createdAt    DateTime @default(now())

  canister Canister @relation(fields: [canisterId], references: [id], onDelete: Cascade)

  @@index([canisterId])
}

model OdometerEntry {
  id        String   @id @default(cuid())
  vehicleId String
  date      DateTime
  odometer  Int
  note      String?
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model RepairEntry {
  id          String         @id @default(cuid())
  vehicleId   String
  date        DateTime
  odometer    Int?
  title       String
  description String?
  category    RepairCategory @default(REPAIR)
  cost        Float          @default(0)
  workshop    String?
  notes       String?
  createdAt   DateTime       @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model CleaningEntry {
  id        String       @id @default(cuid())
  vehicleId String
  date      DateTime
  odometer  Int?
  type      CleaningType @default(FULL)
  cost      Float        @default(0)
  products  String?
  notes     String?
  createdAt DateTime     @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}
